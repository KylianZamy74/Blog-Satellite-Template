---
interface TranslationLink {
  locale: string
  slug: string
}

interface Props {
  originalSlug: string
  currentLocale?: string | null
  translations: TranslationLink[]
}

const { originalSlug, currentLocale, translations } = Astro.props

const LOCALE_LABELS: Record<string, string> = {
  FR: 'Francais',
  EN: 'English',
  NL: 'Nederlands',
  DE: 'Deutsch',
  ES: 'Espanol',
  IT: 'Italiano',
  PT: 'Portugues',
}

const activeLocale = currentLocale?.toUpperCase() || 'FR'

// Construire la map locale -> URL pour la navigation
const localeUrls: Record<string, string> = {
  FR: `/${originalSlug}`,
}
for (const t of translations) {
  localeUrls[t.locale] = `/${t.slug}/${t.locale.toLowerCase()}`
}

// Ne rien afficher s'il n'y a aucune traduction
const hasTranslations = translations.length > 0
---

{hasTranslations && (
  <div class="language-switcher">
    <select id="lang-select" aria-label="Changer de langue">
      <option value="FR" selected={activeLocale === 'FR'}>
        {LOCALE_LABELS['FR']}
      </option>
      {translations.map(({ locale }) => (
        <option value={locale} selected={locale === activeLocale}>
          {LOCALE_LABELS[locale] || locale}
        </option>
      ))}
    </select>
  </div>

  <script define:vars={{ localeUrls }}>
    document.getElementById('lang-select').addEventListener('change', function(e) {
      const locale = e.target.value
      const url = localeUrls[locale]
      if (url) {
        window.location.href = url
      }
    })
  </script>
)}

<style>
  .language-switcher {
    display: inline-block;
  }
  .language-switcher select {
    padding: 0.375rem 0.75rem;
    border: 1px solid #d1d5db;
    border-radius: 0.375rem;
    background-color: white;
    font-size: 0.875rem;
    color: #374151;
    cursor: pointer;
  }
  .language-switcher select:hover {
    border-color: #9ca3af;
  }
  .language-switcher select:focus {
    outline: none;
    border-color: #3b82f6;
    box-shadow: 0 0 0 2px rgba(59, 130, 246, 0.3);
  }
</style>
