---
import BaseLayout from '../layouts/BaseLayout.astro'
import ArticleContent from '../components/ArticleContent.astro'
import LanguageSwitcher from '../components/LanguageSwitcher.astro'
import { getArticleBySlug } from '../lib/api'
import { renderTipTapToHtml } from '../lib/renderer'
import type { TipTapDoc } from '../lib/types'

const { slug } = Astro.params
const siteUrl = import.meta.env.SITE_URL || ''

const article = await getArticleBySlug(slug!)
if (!article) {
  return Astro.redirect('/')
}

const html = renderTipTapToHtml(article.content as TipTapDoc)

const title = article.metaTitle || article.title
const description = article.metaDescription || article.excerpt || ''
const canonicalUrl = `${siteUrl}/${article.slug}`

const translations = article.availableTranslations || []

// Construire les hreflangs pour le SEO
const LOCALE_TO_LANG: Record<string, string> = {
  EN: 'en', NL: 'nl', DE: 'de', ES: 'es', IT: 'it', PT: 'pt',
}

const hreflangs = [
  { locale: 'fr', url: canonicalUrl },
  ...translations.map(t => ({
    locale: LOCALE_TO_LANG[t.locale] || t.locale.toLowerCase(),
    url: `${siteUrl}/${t.slug}/${t.locale.toLowerCase()}`,
  })),
  // x-default pointe vers la version FR
  { locale: 'x-default', url: canonicalUrl },
]

const date = article.publishedAt
  ? new Date(article.publishedAt).toLocaleDateString('fr-FR', {
      day: 'numeric',
      month: 'long',
      year: 'numeric',
    })
  : null
---

<BaseLayout title={title} description={description} ogImage={article.image} canonicalUrl={canonicalUrl} lang="fr" hreflangs={hreflangs}>
  <article class="mx-auto max-w-3xl px-4 py-10">
    {article.image && (
      <img
        src={article.image}
        alt={article.title}
        class="w-full rounded-lg mb-8 aspect-video object-cover"
      />
    )}

    <header class="mb-8">
      <div class="flex items-center justify-between mb-3">
        <h1 class="text-4xl font-bold">{article.title}</h1>
        <LanguageSwitcher
          originalSlug={article.slug}
          translations={translations}
        />
      </div>
      {date && <p class="text-gray-500">{date}</p>}
    </header>

    <ArticleContent html={html} />

    <div class="mt-12 pt-6 border-t border-gray-200">
      <a href="/" class="text-blue-600 hover:text-blue-800 transition-colors">
        ← Retour aux articles
      </a>
    </div>
  </article>
</BaseLayout>
